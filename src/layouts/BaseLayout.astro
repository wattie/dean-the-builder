---
import { Image } from "astro:assets";
import Seo from "../components/Seo.astro";
import "../styles/global.css";
import logo from "../assets/ddb-logo.jpg";

const {
  pageTitle,
  seo,
} = Astro.props as {
  pageTitle: string;
  seo?: { title?: string; description?: string; image?: string };
};

const nav = [
  { href: "/", label: "Home" },
  { href: "/projects/", label: "Projects" },
  { href: "/services/", label: "Services" },
  { href: "/about/", label: "About" },
  { href: "/contact/", label: "Contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <Seo
      title={seo?.title ?? pageTitle}
      description={seo?.description}
      image={seo?.image}
    />
    <style>
      :root { color-scheme: light; }
      body { margin: 0; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; line-height: 1.5; }
      a { color: inherit; }
      .wrap { max-width: 1100px; margin: 0 auto; padding: 24px; }
      header { border-bottom: 1px solid #eee; }
      nav { display: flex; gap: 14px; flex-wrap: wrap; padding: 14px 0; }
      nav a { text-decoration: none; padding: 8px 10px; border-radius: 10px; }
      nav a:hover { background: #f3f3f3; }
      footer { border-top: 1px solid #eee; margin-top: 40px; padding: 20px 0; color: #666; }
      .btn { display:inline-block; padding:10px 14px; border-radius:12px; background:#111; color:#fff; text-decoration:none; }
      .muted { color:#666; }
      h1 { letter-spacing: -0.02em; }
      img { max-width: 100%; height: auto; border-radius: 14px; }
    </style>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <header>
      <div class="wrap">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:16px;">
          <a href="/" style="text-decoration:none; font-weight:700;">
            <Image src={logo} alt="DDB logo" width={140} />
          </a>
          <nav>
            {nav.map((n) => <a href={n.href}>{n.label}</a>)}
          </nav>
        </div>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer>
      <div class="wrap">
        <div>© {new Date().getFullYear()} Dean the Builder</div>
      </div>
    </footer>
  </body>
</html>
