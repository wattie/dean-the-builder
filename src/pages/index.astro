---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import HeroImage from "../components/HeroImage.astro";

const entry = await getEntry("pages", "home");
if (!entry) throw new Error("Missing home page content.");

const { Content } = await entry.render();
---

<BaseLayout pageTitle={entry.data.title} seo={entry.data.seo}>
  <h1>{entry.data.title}</h1>
  {entry.data.heroImage && (
    <HeroImage
      heroImage={entry.data.heroImage}
      heroImageAlt={entry.data.heroImageAlt ?? `${entry.data.title} hero image`}
    />
  )}
  <Content />
  <p style="margin-top:18px;">
    <a class="btn" href="/projects/">View Projects</a>
  </p>
</BaseLayout>
