---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Gallery from "../../components/Gallery.astro";
import { getCollection } from "astro:content";
import { undefined } from "astro:schema";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects
    .filter(p => !p.data.draft)
    .map(p => ({
      params: { slug: p.slug },
      props: { project: p },
    }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const services = project.data.services ?? [];
---

<BaseLayout
  pageTitle={project.data.title}
  seo={{
    title: project.data.seo?.title ?? project.data.title,
    description: project.data.seo?.description ?? project.data.summary,
    image: project.data.seo?.image ?? project.data.featuredImage,
  }}
>
  <div class="flex mb-3.5">
    <div class="flex-1"><h1>{project.data.title}</h1></div>
    <div class="flex-none flex items-center"><a class="muted" href="/projects/">← Back to Projects</a></div>
  </div>

  <div class="grid gap-3.5 mt-4 grid-cols-1 md:grid-cols-2 mb-5">
    <div><strong>Status: </strong>{project.data.status}</div>
    <div><strong>Location: </strong>{project.data.location}</div>
    {project.data.year ? (<div><strong>Year: </strong>{project.data.year}</div>):null}
    {project.data.floorAreaM2 ? (<div><strong>Floor Area: </strong>{project.data.floorAreaM2}</div>):null}
    {project.data.budgetLabel ? (<div><strong>Budget: </strong>{project.data.budgetLabel}</div>):null}
  </div>

  {services.length ? (
    <p class="muted mt-2 mb-3">
      <strong>Services:</strong>
      {services.map((service => <span class="rounded-full bg-dbb-dark text-white py-1.5 px-5 m-1 text-xs">{service}</span>))}
    </p>
  ) : null}

  {project.data.featuredImage && (
    <img src={project.data.featuredImage} alt={`${project.data.title} featured image`} />
  )}

  <div style="margin-top: 16px;">
    <Content />
  </div>

  {project.data.gallery?.length ? (
    <div class="mt-6">
      <Gallery items={project.data.gallery} />
    </div>
  ) : null}
</BaseLayout>
