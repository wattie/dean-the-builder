---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const all = await getCollection("projects");
const projects = all
  .filter(p => !p.data.draft)
  .sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
---

<BaseLayout pageTitle="Projects">
  <h1>Projects</h1>
  <p class="muted">A selection of recent work.</p>

  <div class="grid gap-3.5 mt-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
    {projects.map((p) => (
      <ProjectCard
        href={`/projects/${p.slug}/`}
        title={p.data.title}
        summary={p.data.summary}
        featuredImage={p.data.featuredImage}
        meta={[p.data.location, p.data.year ? String(p.data.year) : ""].filter(Boolean).join(" • ")}
      />
    ))}
  </div>
</BaseLayout>
